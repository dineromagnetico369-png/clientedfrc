# .htaccess - Versión simplificada
# Esta es más fácil de entender y menos propensa a errores

RewriteEngine On

# Verificar si el sistema está bloqueado
RewriteCond %{DOCUMENT_ROOT}/config/estado.txt -f
RewriteCond %{DOCUMENT_ROOT}/config/estado.txt = "bloqueado"

# NO bloquear estas rutas (para que el admin pueda trabajar)
RewriteCond %{REQUEST_URI} !/control-acceso\.php
RewriteCond %{REQUEST_URI} !/config/
RewriteCond %{REQUEST_URI} !/mensaje-bloqueo\.html
RewriteCond %{REQUEST_URI} !/img/

# Redirigir TODO lo demás a mensaje-bloqueo.html
RewriteRule ^ /mensaje-bloqueo.html [L]

# Proteger la carpeta config
<FilesMatch "config">
    Order allow,deny
    Deny from all
</FilesMatch>

# Página de error personalizada
ErrorDocument 403 /mensaje-bloqueo.html
